<?xml version="1.0" encoding="utf-8"?>
<!--
    Règles d'extraction de données : on REFUSE tout backup et tout transfert
    de données (vers Google Drive ou autre device). Les conversations sont
    chiffrées localement et ne doivent jamais quitter le téléphone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
